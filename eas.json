{
	"cli": {
		"version": ">= 14.7.1",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"env": {
				"npm_config_minimum_release_age": "0"
			}
		},
		"preview": {
			"distribution": "internal",
			"android": {
				"buildType": "apk"
			},
			"env": {
				"npm_config_minimum_release_age": "0"
			}
		},
		"production": {
			"env": {
				"npm_config_minimum_release_age": "0"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
